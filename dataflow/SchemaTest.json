{
	"name": "SchemaTest",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "SchemaStagingADLS",
						"type": "DatasetReference"
					},
					"name": "IncrementalData"
				},
				{
					"linkedService": {
						"referenceName": "AzureDataLakeStorageDeltaLake",
						"type": "LinkedServiceReference"
					},
					"name": "ExistingData"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "AzureDataLakeStorageDeltaLake",
						"type": "LinkedServiceReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "AlterRow1"
				},
				{
					"name": "join1"
				},
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          ID as short,",
				"          CALENDAR_DATE as string,",
				"          CALENDAR_CCYY_NBR as double,",
				"          CALENDAR_CCYYMM_NBR as double,",
				"          CALENDAR_CCYYQ_NBR as double,",
				"          CALENDAR_DATE_DESC as string,",
				"          CALENDAR_MTH_BEG_DATE as string,",
				"          CALENDAR_MTH_DAY_DESC as string,",
				"          CALENDAR_MTH_DESC as string,",
				"          CALENDAR_MTH_END_DATE as string,",
				"          CALENDAR_QTR_BEG_DATE as string,",
				"          CALENDAR_QTR_DESC as string,",
				"          CALENDAR_QTR_END_DATE as string,",
				"          CALENDAR_WEEK_BEG_DATE as string,",
				"          CALENDAR_WEEK_DAY_DESC as string,",
				"          CALENDAR_WEEK_DESC as string,",
				"          CALENDAR_WEEK_END_DATE as string,",
				"          CALENDAR_WEEK_NBR as double,",
				"          CALENDAR_WEEK_NBR_MON_SUN as double,",
				"          CALENDAR_YR_BEG_DATE as string,",
				"          CALENDAR_YR_END_DATE as string,",
				"          COMPLETED_QTR_IND as boolean,",
				"          COMPLETED_WEEK_IND as boolean,",
				"          COMPLETED_MTH_IND as boolean,",
				"          COMPLETED_YR_IND as boolean,",
				"          CURRENT_MTH_IND as boolean,",
				"          CURRENT_QTR_IND as boolean,",
				"          CURRENT_WEEK_IND as boolean,",
				"          CURRENT_YR_IND as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> IncrementalData",
				"source(output(",
				"          CALENDAR_DATE as string,",
				"          CALENDAR_CCYY_NBR as string,",
				"          CALENDAR_CCYYMM_NBR as string,",
				"          CALENDAR_CCYYQ_NBR as string,",
				"          CALENDAR_DATE_DESC as string,",
				"          CALENDAR_MTH_BEG_DATE as string,",
				"          CALENDAR_MTH_DAY_DESC as string,",
				"          CALENDAR_MTH_DESC as string,",
				"          CALENDAR_MTH_END_DATE as string,",
				"          CALENDAR_QTR_BEG_DATE as string,",
				"          CALENDAR_QTR_DESC as string,",
				"          CALENDAR_QTR_END_DATE as string,",
				"          CALENDAR_WEEK_BEG_DATE as string,",
				"          CALENDAR_WEEK_DAY_DESC as string,",
				"          CALENDAR_WEEK_DESC as string,",
				"          CALENDAR_WEEK_END_DATE as string,",
				"          CALENDAR_WEEK_NBR as string,",
				"          CALENDAR_WEEK_NBR_MON_SUN as string,",
				"          CALENDAR_YR_BEG_DATE as string,",
				"          CALENDAR_YR_END_DATE as string,",
				"          COMPLETED_QTR_IND as string,",
				"          COMPLETED_WEEK_IND as string,",
				"          COMPLETED_MTH_IND as string,",
				"          COMPLETED_YR_IND as string,",
				"          CURRENT_MTH_IND as string,",
				"          CURRENT_QTR_IND as string,",
				"          CURRENT_WEEK_IND as string,",
				"          CURRENT_YR_IND as string,",
				"          CURR_LAST_COMPLETED_MTH_IND as string,",
				"          CURR_LAST2_COMPLETED_MTH_IND as string,",
				"          LAST_COMPLETED_12_MTH_IND as string,",
				"          LAST_COMPLETED_30_DAY_IND as string,",
				"          LAST_COMPLETED_DAY_IND as string,",
				"          LAST_COMPLETED_MTH_IND as string,",
				"          LAST_COMPLETED_QTR_IND as string,",
				"          LAST_COMPLETED_WEEK_IND as string,",
				"          LAST_COMPLETED_YR_IND as string,",
				"          ID as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'delta',",
				"     fileSystem: 'test',",
				"     folderPath: 'synapsedelta') ~> ExistingData",
				"join1 alterRow(insertIf(isNull(ExistingData@ID)),",
				"     updateIf(!isNull(ExistingData@ID))) ~> AlterRow1",
				"derivedColumn1, ExistingData join(toString(derivedColumn1@ID) == ExistingData@ID,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1",
				"IncrementalData derive(ID = toInteger(byName('ID')),",
				"          CALENDAR_DATE = toTimestamp(byName('CALENDAR_DATE')),",
				"          CALENDAR_CCYY_NBR = toDecimal(byName('CALENDAR_CCYY_NBR'),38,18),",
				"          CALENDAR_CCYYMM_NBR = toDecimal(byName('CALENDAR_CCYYMM_NBR'),38,18),",
				"          CALENDAR_CCYYQ_NBR = toDecimal(byName('CALENDAR_CCYYQ_NBR'),38,18),",
				"          CALENDAR_DATE_DESC = toString(byName('CALENDAR_DATE_DESC')),",
				"          CALENDAR_MTH_BEG_DATE = toTimestamp(byName('CALENDAR_MTH_BEG_DATE')),",
				"          CALENDAR_MTH_DAY_DESC = toString(byName('CALENDAR_MTH_DAY_DESC')),",
				"          CALENDAR_MTH_DESC = toString(byName('CALENDAR_MTH_DESC')),",
				"          CALENDAR_MTH_END_DATE = toTimestamp(byName('CALENDAR_MTH_END_DATE')),",
				"          CALENDAR_QTR_BEG_DATE = toTimestamp(byName('CALENDAR_QTR_BEG_DATE')),",
				"          CALENDAR_QTR_DESC = toString(byName('CALENDAR_QTR_DESC')),",
				"          CALENDAR_QTR_END_DATE = toTimestamp(byName('CALENDAR_QTR_END_DATE')),",
				"          CALENDAR_WEEK_BEG_DATE = toTimestamp(byName('CALENDAR_WEEK_BEG_DATE')),",
				"          CALENDAR_WEEK_DAY_DESC = toString(byName('CALENDAR_WEEK_DAY_DESC')),",
				"          CALENDAR_WEEK_DESC = toString(byName('CALENDAR_WEEK_DESC')),",
				"          CALENDAR_WEEK_END_DATE = toTimestamp(byName('CALENDAR_WEEK_END_DATE')),",
				"          CALENDAR_WEEK_NBR = toDecimal(byName('CALENDAR_WEEK_NBR'),38,18),",
				"          CALENDAR_WEEK_NBR_MON_SUN = toDecimal(byName('CALENDAR_WEEK_NBR_MON_SUN'),38,18),",
				"          CALENDAR_YR_BEG_DATE = toTimestamp(byName('CALENDAR_YR_BEG_DATE')),",
				"          CALENDAR_YR_END_DATE = toTimestamp(byName('CALENDAR_YR_END_DATE')),",
				"          COMPLETED_QTR_IND = toString(byName('COMPLETED_QTR_IND')),",
				"          COMPLETED_WEEK_IND = toString(byName('COMPLETED_WEEK_IND')),",
				"          COMPLETED_MTH_IND = toString(byName('COMPLETED_MTH_IND')),",
				"          COMPLETED_YR_IND = toString(byName('COMPLETED_YR_IND')),",
				"          CURRENT_MTH_IND = toString(byName('CURRENT_MTH_IND')),",
				"          CURRENT_QTR_IND = toString(byName('CURRENT_QTR_IND')),",
				"          CURRENT_WEEK_IND = toString(byName('CURRENT_WEEK_IND')),",
				"          CURRENT_YR_IND = toString(byName('CURRENT_YR_IND')),",
				"          CURR_LAST_COMPLETED_MTH_IND = toString(byName('CURR_LAST_COMPLETED_MTH_IND')),",
				"          CURR_LAST2_COMPLETED_MTH_IND = toString(byName('CURR_LAST2_COMPLETED_MTH_IND')),",
				"          LAST_COMPLETED_12_MTH_IND = toString(byName('LAST_COMPLETED_12_MTH_IND')),",
				"          LAST_COMPLETED_30_DAY_IND = toString(byName('LAST_COMPLETED_30_DAY_IND')),",
				"          LAST_COMPLETED_DAY_IND = toString(byName('LAST_COMPLETED_DAY_IND')),",
				"          LAST_COMPLETED_MTH_IND = toString(byName('LAST_COMPLETED_MTH_IND')),",
				"          LAST_COMPLETED_QTR_IND = toString(byName('LAST_COMPLETED_QTR_IND')),",
				"          LAST_COMPLETED_WEEK_IND = toString(byName('LAST_COMPLETED_WEEK_IND')),",
				"          LAST_COMPLETED_YR_IND = toString(byName('LAST_COMPLETED_YR_IND'))) ~> derivedColumn1",
				"AlterRow1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'delta',",
				"     fileSystem: 'test',",
				"     folderPath: 'synapsedelta',",
				"     mergeSchema: true,",
				"     autoCompact: false,",
				"     optimizedWrite: false,",
				"     vacuum: 0,",
				"     deletable: false,",
				"     insertable: true,",
				"     updateable: true,",
				"     upsertable: false,",
				"     keys:['ID'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     mapColumn(",
				"          ID = derivedColumn1@ID,",
				"          CALENDAR_DATE = derivedColumn1@CALENDAR_DATE,",
				"          CALENDAR_CCYY_NBR = derivedColumn1@CALENDAR_CCYY_NBR,",
				"          CALENDAR_CCYYMM_NBR = derivedColumn1@CALENDAR_CCYYMM_NBR,",
				"          CALENDAR_CCYYQ_NBR = derivedColumn1@CALENDAR_CCYYQ_NBR,",
				"          CALENDAR_DATE_DESC = derivedColumn1@CALENDAR_DATE_DESC,",
				"          CALENDAR_MTH_BEG_DATE = derivedColumn1@CALENDAR_MTH_BEG_DATE,",
				"          CALENDAR_MTH_DAY_DESC = derivedColumn1@CALENDAR_MTH_DAY_DESC,",
				"          CALENDAR_MTH_DESC = derivedColumn1@CALENDAR_MTH_DESC,",
				"          CALENDAR_MTH_END_DATE = derivedColumn1@CALENDAR_MTH_END_DATE,",
				"          CALENDAR_QTR_BEG_DATE = derivedColumn1@CALENDAR_QTR_BEG_DATE,",
				"          CALENDAR_QTR_DESC = derivedColumn1@CALENDAR_QTR_DESC,",
				"          CALENDAR_QTR_END_DATE = derivedColumn1@CALENDAR_QTR_END_DATE,",
				"          CALENDAR_WEEK_BEG_DATE = derivedColumn1@CALENDAR_WEEK_BEG_DATE,",
				"          CALENDAR_WEEK_DAY_DESC = derivedColumn1@CALENDAR_WEEK_DAY_DESC,",
				"          CALENDAR_WEEK_DESC = derivedColumn1@CALENDAR_WEEK_DESC,",
				"          CALENDAR_WEEK_END_DATE = derivedColumn1@CALENDAR_WEEK_END_DATE,",
				"          CALENDAR_WEEK_NBR = derivedColumn1@CALENDAR_WEEK_NBR,",
				"          CALENDAR_WEEK_NBR_MON_SUN = derivedColumn1@CALENDAR_WEEK_NBR_MON_SUN,",
				"          CALENDAR_YR_BEG_DATE = derivedColumn1@CALENDAR_YR_BEG_DATE,",
				"          CALENDAR_YR_END_DATE = derivedColumn1@CALENDAR_YR_END_DATE,",
				"          COMPLETED_QTR_IND = derivedColumn1@COMPLETED_QTR_IND,",
				"          COMPLETED_WEEK_IND = derivedColumn1@COMPLETED_WEEK_IND,",
				"          COMPLETED_MTH_IND = derivedColumn1@COMPLETED_MTH_IND,",
				"          COMPLETED_YR_IND = derivedColumn1@COMPLETED_YR_IND,",
				"          CURRENT_MTH_IND = derivedColumn1@CURRENT_MTH_IND,",
				"          CURRENT_QTR_IND = derivedColumn1@CURRENT_QTR_IND,",
				"          CURRENT_WEEK_IND = derivedColumn1@CURRENT_WEEK_IND,",
				"          CURRENT_YR_IND = derivedColumn1@CURRENT_YR_IND,",
				"          CURR_LAST_COMPLETED_MTH_IND = derivedColumn1@CURR_LAST_COMPLETED_MTH_IND,",
				"          CURR_LAST2_COMPLETED_MTH_IND = derivedColumn1@CURR_LAST2_COMPLETED_MTH_IND,",
				"          LAST_COMPLETED_12_MTH_IND = derivedColumn1@LAST_COMPLETED_12_MTH_IND,",
				"          LAST_COMPLETED_30_DAY_IND = derivedColumn1@LAST_COMPLETED_30_DAY_IND,",
				"          LAST_COMPLETED_DAY_IND = derivedColumn1@LAST_COMPLETED_DAY_IND,",
				"          LAST_COMPLETED_MTH_IND = derivedColumn1@LAST_COMPLETED_MTH_IND,",
				"          LAST_COMPLETED_QTR_IND = derivedColumn1@LAST_COMPLETED_QTR_IND,",
				"          LAST_COMPLETED_WEEK_IND = derivedColumn1@LAST_COMPLETED_WEEK_IND,",
				"          LAST_COMPLETED_YR_IND = derivedColumn1@LAST_COMPLETED_YR_IND",
				"     )) ~> sink1"
			]
		}
	}
}