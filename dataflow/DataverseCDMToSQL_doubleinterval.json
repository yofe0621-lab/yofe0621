{
	"name": "DataverseCDMToSQL_doubleinterval",
	"properties": {
		"description": "Data flow which reads CDM entity, transforms the data and move the data to destination SQL DB",
		"folder": {
			"name": "DataverseToSQL"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"linkedService": {
						"referenceName": "AzureDataLakeStorage1",
						"type": "LinkedServiceReference"
					},
					"name": "currentfolder"
				},
				{
					"linkedService": {
						"referenceName": "AzureSqlDatabase2",
						"type": "LinkedServiceReference"
					},
					"name": "selectmaxversion"
				},
				{
					"linkedService": {
						"referenceName": "AzureDataLakeStorage1",
						"type": "LinkedServiceReference"
					},
					"name": "previousfolder"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "AzureSqlDatabase2",
						"type": "LinkedServiceReference"
					},
					"name": "AzureSQLDB"
				},
				{
					"linkedService": {
						"referenceName": "AzureSqlDatabase2",
						"type": "LinkedServiceReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "IdentifyColumns"
				},
				{
					"name": "AlterRow"
				},
				{
					"name": "Rank"
				},
				{
					"name": "Dedup"
				},
				{
					"name": "FilterFolders"
				},
				{
					"name": "FilterDeletedRows"
				},
				{
					"name": "AddEntityName"
				},
				{
					"name": "SelectDeleteLogColumns"
				},
				{
					"name": "FilterMaxVersion"
				},
				{
					"name": "union1"
				}
			],
			"scriptLines": [
				"parameters{",
				"     dbschema as string (\"dbo\"),",
				"     prefix as string,",
				"     entity as string (\"custgroup\"),",
				"     prefolder as string,",
				"     container as string,",
				"     folder as string",
				"}",
				"source(useSchema: false,",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: true,",
				"     entity: 'custgroup',",
				"     format: 'cdm',",
				"     manifestType: 'model',",
				"     folderPath: '2025-06-17T08.05.26Z',",
				"     fileSystem: 'dataverse-adache3-unq',",
				"     timestampFormats: ['MM/dd/yyyy hh:mm:ss a','MM-dd-yyyy hh:mm:ss a','yyyy.MM.dd hh:mm:ss a','yyyy-MM-dd\\'T\\'HH:mm:ss\\'Z\\'','yyyy-MM-dd\\'T\\'HH:mm:ss.SSS\\'Z\\'','yyyy-MM-dd\\'T\\'HH:mm:ss']) ~> currentfolder",
				"source(output(",
				"          maxversion as long,",
				"          maxmodified as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'query',",
				"     store: 'sqlserver',",
				"     query: (\"SELECT premaxversion AS maxversion FROM \" + $dbschema + \".\" + $prefix + \"DataverseToSQLVerionLog WHERE Entity = '\" + $entity + \"'\"),",
				"     isolationLevel: 'READ_UNCOMMITTED') ~> selectmaxversion",
				"source(output(",
				"          Id as string,",
				"          SinkCreatedOn as timestamp,",
				"          SinkModifiedOn as timestamp,",
				"          priceincludesalestax as long,",
				"          ispublicsector_it as long,",
				"          sysdatastatecode as long,",
				"          bankcustpaymidtable as long,",
				"          clearingperiod as string,",
				"          custgroup as string,",
				"          defaultdimension as long,",
				"          name as string,",
				"          paymtermid as string,",
				"          taxgroupid as string,",
				"          taxperiodpaymentcode_pl as string,",
				"          custwriteoffrefrecid as long,",
				"          custaccountnumseq as long,",
				"          accountingcurrencyexchangeratetype as long,",
				"          reportingcurrencyexchangeratetype as long,",
				"          modifieddatetime as timestamp,",
				"          modifiedby as string,",
				"          modifiedtransactionid as long,",
				"          createddatetime as timestamp,",
				"          createdby as string,",
				"          createdtransactionid as long,",
				"          dataareaid as string,",
				"          recversion as long,",
				"          partition as long,",
				"          sysrowversion as long,",
				"          recid as long,",
				"          tableid as long,",
				"          versionnumber as long,",
				"          createdon as string,",
				"          modifiedon as timestamp,",
				"          IsDelete as boolean",
				"     ),",
				"     useSchema: false,",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     entity: 'custgroup',",
				"     format: 'cdm',",
				"     manifestType: 'model',",
				"     folderPath: ($prefolder),",
				"     fileSystem: ($container)) ~> previousfolder",
				"union1 derive(Id = toString(byName(\"Id\")),",
				"          versionnumber = toLong(byName(\"versionnumber\")),",
				"          IsDelete = toBoolean(byName(\"IsDelete\"))) ~> IdentifyColumns",
				"FilterMaxVersion alterRow(deleteIf(IsDelete==true()),",
				"     upsertIf(isNull(IsDelete)||IsDelete==false())) ~> AlterRow",
				"IdentifyColumns window(over(Id),",
				"     desc(Id, false),",
				"     desc(versionnumber, false),",
				"     desc(SinkModifiedOn, false),",
				"     {_RowVersion} = denseRank()) ~> Rank",
				"Rank filter(toLong(byName(\"_RowVersion\"))==1) ~> Dedup",
				"Dedup, selectmaxversion join(versionnumber > maxversion,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'right')~> FilterFolders",
				"FilterMaxVersion filter(IsDelete==true()) ~> FilterDeletedRows",
				"FilterDeletedRows derive(EntityName = \"generaljournalentry\") ~> AddEntityName",
				"AddEntityName select(mapColumn(",
				"          EntityName,",
				"          RecordId = Id,",
				"          SinkDeleteTime = SinkModifiedOn,",
				"          VersionNumber = versionnumber",
				"     ),",
				"     skipDuplicateMapInputs: false,",
				"     skipDuplicateMapOutputs: true) ~> SelectDeleteLogColumns",
				"FilterFolders filter(versionnumber>toLong(maxversion)) ~> FilterMaxVersion",
				"currentfolder, previousfolder union(byName: true)~> union1",
				"AlterRow sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'dbo',",
				"     tableName: 'custgroup',",
				"     insertable: true,",
				"     updateable: false,",
				"     deletable: true,",
				"     upsertable: true,",
				"     keys:['Id'],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> AzureSQLDB",
				"SelectDeleteLogColumns sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'dbo',",
				"     tableName: 'DeleteLog',",
				"     insertable: true,",
				"     updateable: false,",
				"     deletable: false,",
				"     upsertable: false,",
				"     recreate: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
			]
		}
	}
}