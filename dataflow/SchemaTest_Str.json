{
	"name": "SchemaTest_Str",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "SchemaStagingADLS",
						"type": "DatasetReference"
					},
					"name": "IncrementalData"
				},
				{
					"linkedService": {
						"referenceName": "AzureDataLakeStorageDeltaLake",
						"type": "LinkedServiceReference"
					},
					"name": "ExistingData"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "AzureDataLakeStorageDeltaLake",
						"type": "LinkedServiceReference"
					},
					"name": "sink2"
				}
			],
			"transformations": [
				{
					"name": "join1"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "Update"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          ID as string,",
				"          CALENDAR_DATE as string,",
				"          CALENDAR_CCYY_NBR as string,",
				"          CALENDAR_CCYYMM_NBR as string,",
				"          CALENDAR_CCYYQ_NBR as string,",
				"          CALENDAR_DATE_DESC as string,",
				"          CALENDAR_MTH_BEG_DATE as string,",
				"          CALENDAR_MTH_DAY_DESC as string,",
				"          CALENDAR_MTH_DESC as string,",
				"          CALENDAR_MTH_END_DATE as string,",
				"          CALENDAR_QTR_BEG_DATE as string,",
				"          CALENDAR_QTR_DESC as string,",
				"          CALENDAR_QTR_END_DATE as string,",
				"          CALENDAR_WEEK_BEG_DATE as string,",
				"          CALENDAR_WEEK_DAY_DESC as string,",
				"          CALENDAR_WEEK_DESC as string,",
				"          CALENDAR_WEEK_END_DATE as string,",
				"          CALENDAR_WEEK_NBR as string,",
				"          CALENDAR_WEEK_NBR_MON_SUN as string,",
				"          CALENDAR_YR_BEG_DATE as string,",
				"          CALENDAR_YR_END_DATE as string,",
				"          COMPLETED_QTR_IND as string,",
				"          COMPLETED_WEEK_IND as string,",
				"          COMPLETED_MTH_IND as string,",
				"          COMPLETED_YR_IND as string,",
				"          CURRENT_MTH_IND as string,",
				"          CURRENT_QTR_IND as string,",
				"          CURRENT_WEEK_IND as string,",
				"          CURRENT_YR_IND as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> IncrementalData",
				"source(output(",
				"          CALENDAR_DATE as string,",
				"          CALENDAR_CCYY_NBR as string,",
				"          CALENDAR_CCYYMM_NBR as string,",
				"          CALENDAR_CCYYQ_NBR as string,",
				"          CALENDAR_DATE_DESC as string,",
				"          CALENDAR_MTH_BEG_DATE as string,",
				"          CALENDAR_MTH_DAY_DESC as string,",
				"          CALENDAR_MTH_DESC as string,",
				"          CALENDAR_MTH_END_DATE as string,",
				"          CALENDAR_QTR_BEG_DATE as string,",
				"          CALENDAR_QTR_DESC as string,",
				"          CALENDAR_QTR_END_DATE as string,",
				"          CALENDAR_WEEK_BEG_DATE as string,",
				"          CALENDAR_WEEK_DAY_DESC as string,",
				"          CALENDAR_WEEK_DESC as string,",
				"          CALENDAR_WEEK_END_DATE as string,",
				"          CALENDAR_WEEK_NBR as string,",
				"          CALENDAR_WEEK_NBR_MON_SUN as string,",
				"          CALENDAR_YR_BEG_DATE as string,",
				"          CALENDAR_YR_END_DATE as string,",
				"          COMPLETED_QTR_IND as string,",
				"          COMPLETED_WEEK_IND as string,",
				"          COMPLETED_MTH_IND as string,",
				"          COMPLETED_YR_IND as string,",
				"          CURRENT_MTH_IND as string,",
				"          CURRENT_QTR_IND as string,",
				"          CURRENT_WEEK_IND as string,",
				"          CURRENT_YR_IND as string,",
				"          CURR_LAST_COMPLETED_MTH_IND as string,",
				"          CURR_LAST2_COMPLETED_MTH_IND as string,",
				"          LAST_COMPLETED_12_MTH_IND as string,",
				"          LAST_COMPLETED_30_DAY_IND as string,",
				"          LAST_COMPLETED_DAY_IND as string,",
				"          LAST_COMPLETED_MTH_IND as string,",
				"          LAST_COMPLETED_QTR_IND as string,",
				"          LAST_COMPLETED_WEEK_IND as string,",
				"          LAST_COMPLETED_YR_IND as string,",
				"          ID as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'delta',",
				"     fileSystem: 'test',",
				"     folderPath: 'synapsedelta') ~> ExistingData",
				"derivedColumn1, select1 join(ID == ExistingID,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1",
				"IncrementalData derive(ID = toString(byName('ID')),",
				"          CALENDAR_DATE = toString(byName('CALENDAR_DATE')),",
				"          CALENDAR_CCYY_NBR = toString(byName('CALENDAR_CCYY_NBR')),",
				"          CALENDAR_CCYYMM_NBR = toString(byName('CALENDAR_CCYYMM_NBR')),",
				"          CALENDAR_CCYYQ_NBR = toString(byName('CALENDAR_CCYYQ_NBR')),",
				"          CALENDAR_DATE_DESC = toString(byName('CALENDAR_DATE_DESC')),",
				"          CALENDAR_MTH_BEG_DATE = toString(byName('CALENDAR_MTH_BEG_DATE')),",
				"          CALENDAR_MTH_DAY_DESC = toString(byName('CALENDAR_MTH_DAY_DESC')),",
				"          CALENDAR_MTH_DESC = toString(byName('CALENDAR_MTH_DESC')),",
				"          CALENDAR_MTH_END_DATE = toString(byName('CALENDAR_MTH_END_DATE')),",
				"          CALENDAR_QTR_BEG_DATE = toString(byName('CALENDAR_QTR_BEG_DATE')),",
				"          CALENDAR_QTR_DESC = toString(byName('CALENDAR_QTR_DESC')),",
				"          CALENDAR_QTR_END_DATE = toString(byName('CALENDAR_QTR_END_DATE')),",
				"          CALENDAR_WEEK_BEG_DATE = toString(byName('CALENDAR_WEEK_BEG_DATE')),",
				"          CALENDAR_WEEK_DAY_DESC = toString(byName('CALENDAR_WEEK_DAY_DESC')),",
				"          CALENDAR_WEEK_DESC = toString(byName('CALENDAR_WEEK_DESC')),",
				"          CALENDAR_WEEK_END_DATE = toString(byName('CALENDAR_WEEK_END_DATE')),",
				"          CALENDAR_WEEK_NBR = toString(byName('CALENDAR_WEEK_NBR')),",
				"          CALENDAR_WEEK_NBR_MON_SUN = toString(byName('CALENDAR_WEEK_NBR_MON_SUN')),",
				"          CALENDAR_YR_BEG_DATE = toString(byName('CALENDAR_YR_BEG_DATE')),",
				"          CALENDAR_YR_END_DATE = toString(byName('CALENDAR_YR_END_DATE')),",
				"          COMPLETED_QTR_IND = toString(byName('COMPLETED_QTR_IND')),",
				"          COMPLETED_WEEK_IND = toString(byName('COMPLETED_WEEK_IND')),",
				"          COMPLETED_MTH_IND = toString(byName('COMPLETED_MTH_IND')),",
				"          COMPLETED_YR_IND = toString(byName('COMPLETED_YR_IND')),",
				"          CURRENT_MTH_IND = toString(byName('CURRENT_MTH_IND')),",
				"          CURRENT_QTR_IND = toString(byName('CURRENT_QTR_IND')),",
				"          CURRENT_WEEK_IND = toString(byName('CURRENT_WEEK_IND')),",
				"          CURRENT_YR_IND = toString(byName('CURRENT_YR_IND')),",
				"          CURR_LAST_COMPLETED_MTH_IND = toString(byName('CURR_LAST_COMPLETED_MTH_IND')),",
				"          CURR_LAST2_COMPLETED_MTH_IND = toString(byName('CURR_LAST2_COMPLETED_MTH_IND')),",
				"          LAST_COMPLETED_12_MTH_IND = toString(byName('LAST_COMPLETED_12_MTH_IND')),",
				"          LAST_COMPLETED_30_DAY_IND = toString(byName('LAST_COMPLETED_30_DAY_IND')),",
				"          LAST_COMPLETED_DAY_IND = toString(byName('LAST_COMPLETED_DAY_IND')),",
				"          LAST_COMPLETED_MTH_IND = toString(byName('LAST_COMPLETED_MTH_IND')),",
				"          LAST_COMPLETED_QTR_IND = toString(byName('LAST_COMPLETED_QTR_IND')),",
				"          LAST_COMPLETED_WEEK_IND = toString(byName('LAST_COMPLETED_WEEK_IND')),",
				"          LAST_COMPLETED_YR_IND = toString(byName('LAST_COMPLETED_YR_IND'))) ~> derivedColumn1",
				"join1 alterRow(updateIf(!isNull(ExistingID)),",
				"     insertIf(isNull(ExistingID))) ~> Update",
				"ExistingData select(mapColumn(",
				"          ExistingID = ID",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"Update sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'delta',",
				"     fileSystem: 'test',",
				"     folderPath: 'synapsedelta',",
				"     mergeSchema: false,",
				"     autoCompact: false,",
				"     optimizedWrite: false,",
				"     vacuum: 0,",
				"     deletable: false,",
				"     insertable: true,",
				"     updateable: true,",
				"     upsertable: false,",
				"     keys:['ID'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     mapColumn(",
				"          ID,",
				"          CALENDAR_DATE,",
				"          CALENDAR_CCYY_NBR,",
				"          CALENDAR_CCYYMM_NBR,",
				"          CALENDAR_CCYYQ_NBR,",
				"          CALENDAR_DATE_DESC,",
				"          CALENDAR_MTH_BEG_DATE,",
				"          CALENDAR_MTH_DAY_DESC,",
				"          CALENDAR_MTH_DESC,",
				"          CALENDAR_MTH_END_DATE,",
				"          CALENDAR_QTR_BEG_DATE,",
				"          CALENDAR_QTR_DESC,",
				"          CALENDAR_QTR_END_DATE,",
				"          CALENDAR_WEEK_BEG_DATE,",
				"          CALENDAR_WEEK_DAY_DESC,",
				"          CALENDAR_WEEK_DESC,",
				"          CALENDAR_WEEK_END_DATE,",
				"          CALENDAR_WEEK_NBR,",
				"          CALENDAR_WEEK_NBR_MON_SUN,",
				"          CALENDAR_YR_BEG_DATE,",
				"          CALENDAR_YR_END_DATE,",
				"          COMPLETED_QTR_IND,",
				"          COMPLETED_WEEK_IND,",
				"          COMPLETED_MTH_IND,",
				"          COMPLETED_YR_IND,",
				"          CURRENT_MTH_IND,",
				"          CURRENT_QTR_IND,",
				"          CURRENT_WEEK_IND,",
				"          CURRENT_YR_IND,",
				"          CURR_LAST_COMPLETED_MTH_IND,",
				"          CURR_LAST2_COMPLETED_MTH_IND,",
				"          LAST_COMPLETED_12_MTH_IND,",
				"          LAST_COMPLETED_30_DAY_IND,",
				"          LAST_COMPLETED_DAY_IND,",
				"          LAST_COMPLETED_MTH_IND,",
				"          LAST_COMPLETED_QTR_IND,",
				"          LAST_COMPLETED_WEEK_IND,",
				"          LAST_COMPLETED_YR_IND",
				"     )) ~> sink2"
			]
		}
	}
}